VITE_GROQ_API_KEY=your_groq_api_key_here

# Backend API URL (Render URL in production)
# Local example: http://localhost:3001
# Production example: https://your-backend-name.onrender.com
VITE_API_BASE_URL=http://localhost:3001

# Optional: Google Places API Key for better hospital search results
# Get your key from: https://console.cloud.google.com/apis/credentials
# If not provided, the app will use OpenStreetMap (free, no key required)
VITE_GOOGLE_PLACES_API_KEY=your_google_api_key_here
